@page "/orders"
@inject OrderApiService Api
@inject NavigationManager Nav

<PageTitle>Pedidos — Good Hamburger</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Pedidos</h1>
    <a href="orders/new" class="btn btn-warning">+ Novo Pedido</a>
</div>

@if (orders is null && errorMessage is null)
{
    <p>Carregando...</p>
}
else if (orders is not null && orders.Count == 0)
{
    <p class="text-muted">Nenhum pedido cadastrado ainda.</p>
}
else if (orders is not null)
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Sanduíche</th>
                <th>Batata</th>
                <th>Refrigerante</th>
                <th>Subtotal</th>
                <th>Desconto</th>
                <th>Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in orders)
            {
                <tr>
                    <td>@order.Sandwich.Name</td>
                    <td>@(order.Fries?.Name ?? "—")</td>
                    <td>@(order.Drink?.Name ?? "—")</td>
                    <td>R$ @order.Subtotal.ToString("F2")</td>
                    <td>
                        @if (order.DiscountPercentage > 0)
                        {
                            <span class="badge bg-success">@order.DiscountPercentage%</span>
                            <span class="ms-1 text-danger">-R$ @order.DiscountAmount.ToString("F2")</span>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </td>
                    <td><strong>R$ @order.Total.ToString("F2")</strong></td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteOrder(order.Id)">
                            Excluir
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@code {
    private List<OrderResponse>? orders;
    private string? errorMessage;

    protected override async Task OnInitializedAsync() => await LoadOrders();

    private async Task LoadOrders()
    {
        try
        {
            errorMessage = null;
            orders = await Api.GetOrdersAsync();
        }
        catch
        {
            errorMessage = "Não foi possível carregar os pedidos.";
        }
    }

    private async Task DeleteOrder(Guid id)
    {
        try
        {
            await Api.DeleteOrderAsync(id);
            await LoadOrders();
        }
        catch
        {
            errorMessage = "Erro ao excluir o pedido.";
        }
    }
}
